<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36 Edg/146.0.0.0" version="29.6.3">
  <diagram id="scheduler-ppo-arch" name="Scheduler PPO Architecture">
    <mxGraphModel dx="1773" dy="975" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=18;fontStyle=1;" value="&lt;b&gt;Low Level Agent - PPO Network Architecture&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="540" x="630" y="30" as="geometry" />
        </mxCell>
        <mxCell id="statebox" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" value="&lt;b&gt;Structured State From Environment&lt;/b&gt;&lt;br&gt;EnvState&lt;br&gt;- fea_j_tensor: [B,N,14]&lt;br&gt;- fea_m_tensor: [B,M,9]&lt;br&gt;- candidate_tensor: [B,J]&lt;br&gt;- dynamic_pair_mask: [B,J,M]&lt;br&gt;- fea_pairs_tensor: [B,J,M,9]&lt;br&gt;- op_mask / mch_mask / comp_idx" vertex="1">
          <mxGeometry height="180" width="260" x="40" y="120" as="geometry" />
        </mxCell>
        <mxCell id="fea_j" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" value="&lt;b&gt;Operation Features&lt;/b&gt;&lt;br&gt;fea_j [B,N,14]&lt;br&gt;Examples:&lt;br&gt;- scheduled_flag&lt;br&gt;- op_ct_lb&lt;br&gt;- op_min_pt&lt;br&gt;- slack / CR / tardy" vertex="1">
          <mxGeometry height="150" width="240" x="40" y="350" as="geometry" />
        </mxCell>
        <mxCell id="fea_m" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" value="&lt;b&gt;Machine Features&lt;/b&gt;&lt;br&gt;fea_m [B,M,9]&lt;br&gt;Examples:&lt;br&gt;- available job/op count&lt;br&gt;- mch_mean_pt&lt;br&gt;- mch_waiting_time&lt;br&gt;- tardiness pressure / g0 g1 g2" vertex="1">
          <mxGeometry height="160" width="240" x="40" y="530" as="geometry" />
        </mxCell>
        <mxCell id="pair_aux" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;" value="&lt;b&gt;Pair / Routing Context&lt;/b&gt;&lt;br&gt;- candidate_tensor [B,J]&lt;br&gt;- dynamic_pair_mask [B,J,M]&lt;br&gt;- fea_pairs [B,J,M,9]&lt;br&gt;- op_mask / mch_mask / comp_idx" vertex="1">
          <mxGeometry height="140" width="240" x="40" y="720" as="geometry" />
        </mxCell>
        <mxCell id="encoder_group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;fontStyle=1;" value="" vertex="1">
          <mxGeometry height="760" width="420" x="360" y="100" as="geometry" />
        </mxCell>
        <mxCell id="j_encoder" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;j_encoder&lt;/b&gt;&lt;br&gt;Input: 14&lt;br&gt;MLP: 14 -&amp;gt; 64 -&amp;gt; 64 -&amp;gt; 64&lt;br&gt;Hidden activation: ReLU&lt;br&gt;Then: LayerNorm + Dropout&lt;br&gt;Output: fea_j [B,N,64]" vertex="1">
          <mxGeometry height="150" width="320" x="420" y="350" as="geometry" />
        </mxCell>
        <mxCell id="m_encoder" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;m_encoder&lt;/b&gt;&lt;br&gt;Input: 9&lt;br&gt;MLP: 9 -&amp;gt; 64 -&amp;gt; 64 -&amp;gt; 64&lt;br&gt;Hidden activation: ReLU&lt;br&gt;Then: LayerNorm + Dropout&lt;br&gt;Output: fea_m [B,M,64]" vertex="1">
          <mxGeometry height="150" width="320" x="420" y="535" as="geometry" />
        </mxCell>
        <mxCell id="global_pool" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;Global Pooling&lt;/b&gt;&lt;br&gt;nonzero_averaging&lt;br&gt;from fea_j -&amp;gt; fea_j_global [B,64]&lt;br&gt;from fea_m -&amp;gt; fea_m_global [B,64]" vertex="1">
          <mxGeometry height="100" width="320" x="410" y="150" as="geometry" />
        </mxCell>
        <mxCell id="shared_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;" value="&lt;b&gt;Purpose&lt;/b&gt;&lt;br&gt;Encode operation and machine state into shared embeddings before branching to actor / critic." vertex="1">
          <mxGeometry height="90" width="320" x="410" y="730" as="geometry" />
        </mxCell>
        <mxCell id="actor_prep" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" value="&lt;b&gt;Actor Feature Assembly&lt;/b&gt;&lt;br&gt;For each (job, machine) pair:&lt;br&gt;1. Gather candidate op embedding fea_j_jc [64]&lt;br&gt;2. Serialize machine embedding fea_m [64]&lt;br&gt;3. Add global op summary fea_j_global [64]&lt;br&gt;4. Add global machine summary fea_m_global [64]&lt;br&gt;5. Add pair feature fea_pairs [9]&lt;br&gt;&lt;br&gt;candidate_feature [B, J*M, 265]" vertex="1">
          <mxGeometry height="220" width="340" x="980" y="220" as="geometry" />
        </mxCell>
        <mxCell id="actor" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" value="&lt;b&gt;Actor Network&lt;/b&gt;&lt;br&gt;Input dim: 265&lt;br&gt;num_mlp_layers_actor = 3&lt;br&gt;hidden_dim_actor = 512&lt;br&gt;Structure: 265 -&amp;gt; 512 -&amp;gt; 512 -&amp;gt; 1&lt;br&gt;Activation: tanh on hidden layers&lt;br&gt;Output: one score per pair" vertex="1">
          <mxGeometry height="150" width="340" x="980" y="495" as="geometry" />
        </mxCell>
        <mxCell id="actor_out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" value="&lt;b&gt;Policy Output&lt;/b&gt;&lt;br&gt;candidate_scores [B, J*M]&lt;br&gt;- invalid pairs masked to -inf using dynamic_pair_mask&lt;br&gt;- softmax over valid pairs&lt;br&gt;Final output: pi [B, J*M]" vertex="1">
          <mxGeometry height="120" width="340" x="980" y="700" as="geometry" />
        </mxCell>
        <mxCell id="critic_prep" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;Critic Feature Assembly&lt;/b&gt;&lt;br&gt;global_feature = concat(fea_j_global, fea_m_global)&lt;br&gt;Input dim: 64 + 64 = 128" vertex="1">
          <mxGeometry height="90" width="320" x="1450" y="260" as="geometry" />
        </mxCell>
        <mxCell id="critic" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;Critic Network&lt;/b&gt;&lt;br&gt;Input dim: 128&lt;br&gt;num_mlp_layers_critic = 3&lt;br&gt;hidden_dim_critic = 256&lt;br&gt;Structure: 128 -&amp;gt; 256 -&amp;gt; 256 -&amp;gt; 1&lt;br&gt;Activation: tanh on hidden layers" vertex="1">
          <mxGeometry height="130" width="320" x="1450" y="425" as="geometry" />
        </mxCell>
        <mxCell id="critic_out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;Value Output&lt;/b&gt;&lt;br&gt;v [B,1]&lt;br&gt;State value for PPO advantage / value target computation" vertex="1">
          <mxGeometry height="90" width="320" x="1450" y="605" as="geometry" />
        </mxCell>
        <mxCell id="action_step" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" value="&lt;b&gt;Environment Step&lt;/b&gt;&lt;br&gt;Greedy or sampled pair action&lt;br&gt;-&amp;gt; dispatch selected candidate op to selected machine&lt;br&gt;-&amp;gt; next state + reward" vertex="1">
