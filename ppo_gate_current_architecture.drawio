        </mxCell>
        <mxCell id="policytitle" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" value="&lt;b&gt;Actor / Policy Head&lt;/b&gt;" vertex="1">
          <mxGeometry height="50" width="220" x="1190" y="120" as="geometry" />
        </mxCell>
        <mxCell id="policyhead" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;align=left;spacingLeft=10;" value="&lt;b&gt;Policy Head&lt;/b&gt;&lt;br&gt;Linear(512 -&gt; 2)&lt;br&gt;&lt;br&gt;Output logits for:&lt;br&gt;- action 0: HOLD&lt;br&gt;- action 1: RELEASE" vertex="1">
          <mxGeometry height="120" width="310" x="1150" y="205" as="geometry" />
