        <mxCell id="value2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacingLeft=10;" value="&lt;b&gt;Value Layer 2&lt;/b&gt;&lt;br&gt;Linear(512 -&gt; 512)&lt;br&gt;ReLU&lt;br&gt;LayerNorm(512)" vertex="1">
