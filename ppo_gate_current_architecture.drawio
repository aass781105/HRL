        <mxCell id="value3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacingLeft=10;" value="&lt;b&gt;Value Output&lt;/b&gt;&lt;br&gt;Linear(512 -&gt; 1)&lt;br&gt;&lt;br&gt;Output: V(s)" vertex="1">
          <mxGeometry height="70" width="330" x="1150" y="860" as="geometry" />
        </mxCell>
        <mxCell id="ppo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;PPO Update&lt;/b&gt;&lt;br&gt;Source: train_ppo_gate.py&lt;br&gt;&lt;br&gt;1. Collect episodes from 2 envs&lt;br&gt;2. Compute GAE(γ=0.99, λ=0.95)&lt;br&gt;3. Normalize advantage&lt;br&gt;4. PPO clipped policy loss&lt;br&gt;5. Value MSE loss&lt;br&gt;6. Entropy bonus&lt;br&gt;7. Gradient clipping&lt;br&gt;&lt;br&gt;Current tuned2 example:&lt;br&gt;- lr 4e-5 -&gt; 1.5e-5&lt;br&gt;- entropy_coef = 0.012&lt;br&gt;- value_coef = 0.2&lt;br&gt;- update_epochs = 3&lt;br&gt;- minibatch_size = 128" vertex="1">
          <mxGeometry height="260" width="420" x="1640" y="450" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;" value="&lt;b&gt;Current Main-Line Interpretation&lt;/b&gt;&lt;br&gt;The network does not directly see future jobs.&lt;br&gt;It sees current buffer / WIP / machine-load summary features, and learns when HOLD vs RELEASE improves long-term TD." vertex="1">
          <mxGeometry height="120" width="420" x="1640" y="760" as="geometry" />
        </mxCell>
