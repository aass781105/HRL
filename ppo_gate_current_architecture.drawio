  <diagram id="ppo-gate-current-arch" name="PPO Gate Current Architecture">
    <mxGraphModel dx="1134" dy="624" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=18;fontStyle=1;" value="&lt;b&gt;Hight Level agent - PPO Gate Architecture&lt;/b&gt;" vertex="1">
          <mxGeometry height="50" width="760" x="700" y="40" as="geometry" />
        </mxCell>
        <mxCell id="state" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" value="&lt;b&gt;Environment State (18-D)&lt;/b&gt;&lt;br&gt;Source: calculate_ddqn_state(...) in model/ddqn_model.py&lt;br&gt;&lt;br&gt;1. log1p(buffer_size)&lt;br&gt;2. avg machine remaining load&lt;br&gt;3. min machine remaining load&lt;br&gt;4. weighted idle&lt;br&gt;5. buffer tardiness ratio&lt;br&gt;6. buffer min slack&lt;br&gt;7. buffer avg slack&lt;br&gt;8. WIP min slack&lt;br&gt;9. WIP avg slack&lt;br&gt;10. WIP tardy ratio&lt;br&gt;11. machine load std&lt;br&gt;12. c_log = clip(planned_td/(total_rem_work+1), 0, 10)&lt;br&gt;13. buffer slack std&lt;br&gt;14. WIP slack std&lt;br&gt;15. WIP count&lt;br&gt;16. max_load - min_load&lt;br&gt;17. slack density&lt;br&gt;18. unweighted idle&lt;br&gt;&lt;br&gt;All time-like terms are normalized by time_scale = mean_pt." vertex="1">
          <mxGeometry height="470" width="410" x="40" y="140" as="geometry" />
        </mxCell>
        <mxCell id="envnote" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;" value="&lt;b&gt;Action Space&lt;/b&gt;&lt;br&gt;0 = HOLD&lt;br&gt;1 = RELEASE&lt;br&gt;&lt;br&gt;Env: EventGateEnv&lt;br&gt;Observation space shape = (18,)" vertex="1">
          <mxGeometry height="120" width="410" x="40" y="640" as="geometry" />
        </mxCell>
        <mxCell id="trunkgroup" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="" vertex="1">
