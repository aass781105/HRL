          <mxGeometry height="70" width="320" x="620" y="150" as="geometry" />
        </mxCell>
        <mxCell id="trunk1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;spacingLeft=10;" value="&lt;b&gt;Trunk Layer 1&lt;/b&gt;&lt;br&gt;Linear(18 -&gt; 512)&lt;br&gt;ReLU&lt;br&gt;LayerNorm(512)" vertex="1">
